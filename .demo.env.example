# Template for .demo.env. The real file is created by scripts/deploy.ps1
# after a successful Azure deployment. Do NOT commit .demo.env (it is in
# .gitignore) — it contains live subscription keys.

# Gateway URL — Azure API Management gateway endpoint
GATEWAY_URL=https://apim-aigw-lab-XXXXXX.azure-api.net

# APIM resource name (for az CLI calls)
APIM_NAME=apim-aigw-lab-XXXXXX

# Default deployment alias used in the AOAI URL path
DEPLOYMENT_ALIAS=chat
MODEL_NAME=gpt-4o
RESOURCE_GROUP=rg-aigw-lab

# Per-tier subscription keys (one per APIM Product)
KEY_FAST=<placeholder-32-char-key>
KEY_STANDARD=<placeholder-32-char-key>
KEY_BATCH=<placeholder-32-char-key>

# External-models API (OpenAI/Anthropic + AOAI fallback)
EXTERNAL_GATEWAY_URL=https://apim-aigw-lab-XXXXXX.azure-api.net/external/v1
EXTERNAL_GATEWAY_KEY=<placeholder-32-char-key>

# MCP gateway sibling API
MCP_GATEWAY_URL=https://apim-aigw-lab-XXXXXX.azure-api.net/mcp
MCP_GATEWAY_KEY=<placeholder-32-char-key>

# Optional resource handles (for ad-hoc az/kusto queries)
AOAI_PRIMARY_NAME=aoai-aigw-swc-XXXXXX
AOAI_SECONDARY_NAME=aoai-aigw-frc-XXXXXX
AOAI_TERTIARY_NAME=aoai-aigw-swn-XXXXXX
APP_INSIGHTS_NAME=appi-aigw-lab
WORKSPACE_NAME=law-aigw-lab
REDIS_NAME=redis-aigw-XXXXXX
CONTENT_SAFETY_NAME=cs-aigw-XXXXXX
