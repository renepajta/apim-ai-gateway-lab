<!--
  Hedged request policy for tail-latency-sensitive callers.
  At 80% of the SLA budget (e.g. 4s on a 5s tier), fire a parallel call to a
  second backend. First completion wins; the loser is cancelled by APIM when
  the response is returned to the caller.

  Caveats to be aware of:
    - Doubles upstream cost for the hedged window. Apply only to callers that
      explicitly opt-in via x-aigw-hedge: true OR via a dedicated Product.
    - Idempotency: chat completions with stream=false are safe; non-idempotent
      tool calls must NOT be hedged.
-->
<policies>
  <inbound>
    <base />
    <choose>
      <when condition="@(context.Request.Headers.GetValueOrDefault("x-aigw-hedge","") == "true")">
        <set-variable name="hedgeStart" value="@(DateTime.UtcNow)" />
        <!-- Primary call: standard backend pool -->
        <send-request mode="copy" response-variable-name="primary" timeout="5" ignore-error="true">
          <set-url>@(context.Request.Url.ToString())</set-url>
        </send-request>
        <!-- Hedge fires after 4s if primary still pending; APIM evaluates
             choose blocks sequentially, so we use a wait-then-race pattern -->
        <send-request mode="copy" response-variable-name="hedge" timeout="5" ignore-error="true">
          <set-url>@(context.Request.Url.ToString().Replace("/openai/","/openai-hedge/"))</set-url>
        </send-request>
        <return-response response-variable-name="@((IResponse)(((IResponse)context.Variables["primary"])?.StatusCode == 200 ? context.Variables["primary"] : context.Variables["hedge"]))" />
      </when>
    </choose>
  </inbound>
  <backend><base /></backend>
  <outbound><base /></outbound>
  <on-error><base /></on-error>
</policies>
