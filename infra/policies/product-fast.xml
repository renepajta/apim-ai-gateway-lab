<!--
  Product policy: tier-fast (intended for chat / the assistant UI short turns)
  read timeout 8s for demo (production tunes to 30s). buffer-response="false" so HTTP/2 RST or client TCP close
  propagates to AOAI as connection close, releasing PTU/quota immediately.
-->
<policies>
  <inbound>
    <base />
  </inbound>
  <backend>
    <forward-request timeout="8" buffer-response="false" />
  </backend>
  <outbound>
    <base />
  </outbound>
  <on-error>
    <base />
  </on-error>
</policies>
