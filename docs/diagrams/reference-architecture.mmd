    classDef health  fill:#FFE4B5,stroke:#B8651B,stroke-width:1.5px,color:#5C3A0E
    classDef ext     fill:#FFD9D9,stroke:#A4262C,stroke-width:1.5px,color:#5B1A1F
    classDef optional fill:#F3F2F1,stroke:#605E5C,stroke-width:1.5px,stroke-dasharray:5 5,color:#323130

