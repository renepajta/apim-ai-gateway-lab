    style AOAI  fill:#E1EFFA,stroke:#0078D4,stroke-width:3px,color:#004578
    style REDIS fill:#F1EAF8,stroke:#5C2D91,stroke-width:3px,color:#3B1E5E
    style HP    fill:#FFF1DC,stroke:#B8651B,stroke-width:3px,color:#5C3A0E
